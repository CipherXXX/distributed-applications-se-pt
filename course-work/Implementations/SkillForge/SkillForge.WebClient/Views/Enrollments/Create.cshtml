@model EnrollmentDto
@{
    ViewData["Title"] = "Create Enrollment";
}

<h2 class="page-title">Create Enrollment</h2>
<div class="card-forge p-4" style="max-width: 420px;">
    <form asp-action="Create" method="post" class="form-forge">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label asp-for="StudentId" class="form-label">Student ID</label>
            <input asp-for="StudentId" type="number" class="form-control" />
            <span asp-validation-for="StudentId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="CourseId" class="form-label">Course ID</label>
            <input asp-for="CourseId" type="number" class="form-control" />
            <span asp-validation-for="CourseId" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-forge btn-forge-primary">Create</button>
            <a asp-action="Index" class="btn btn-forge btn-forge-secondary">Cancel</a>
        </div>
    </form>
</div>
