@model PagedResult<StudentDto>
@{
    ViewData["Title"] = "Students";
    var isAdmin = Context.IsAdmin();
}

<h2 class="page-title">Students</h2>
<div class="card-forge p-3 mb-4">
    <div class="d-flex flex-wrap gap-2 align-items-end">
        <form method="get" class="row g-2 flex-grow-1 align-items-end">
            <div class="col-auto"><input name="firstName" value="@Context.Request.Query["firstName"]" class="form-control" placeholder="First name" /></div>
            <div class="col-auto"><input name="lastName" value="@Context.Request.Query["lastName"]" class="form-control" placeholder="Last name" /></div>
            <div class="col-auto"><input name="email" value="@Context.Request.Query["email"]" class="form-control" placeholder="Email" /></div>
            <input type="hidden" name="page" value="1" />
            <div class="col-auto"><button type="submit" class="btn btn-forge btn-forge-secondary">Search</button></div>
        </form>
        @if (isAdmin)
        {
            <a asp-action="Create" class="btn btn-forge btn-forge-primary">Create New</a>
        }
    </div>
</div>

<div class="card-forge overflow-hidden">
    <table class="table table-forge mb-0">
        <thead>
            <tr>
                @if (isAdmin)
                {
                    <th>Id</th>
                }
                <th style="width: 60px;">Photo</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
                <th>Birth Date</th>
                @if (isAdmin)
                {
                    <th></th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model?.Items ?? new List<StudentDto>())
            {
                <tr>
                    @if (isAdmin)
                    {
                        <td>@s.Id</td>
                    }
                    <td>
                        @if (!string.IsNullOrEmpty(s.ProfileImageUrl))
                        {
                            <img src="@Url.Action("Download", "Files", new { path = s.ProfileImageUrl })" alt="" class="rounded" style="max-height: 40px; max-width: 40px; object-fit: cover;" />
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>@s.FirstName</td>
                    <td>@s.LastName</td>
                    <td>@s.Email</td>
                    <td>@s.BirthDate.ToString("d")</td>
                    @if (isAdmin)
                    {
                        <td>
                            <a asp-action="Details" asp-route-id="@s.Id" class="btn-forge-link">Details</a>
                            <span class="text-muted">|</span>
                            <a asp-action="Edit" asp-route-id="@s.Id" class="btn-forge-link">Edit</a>
                            <span class="text-muted">|</span>
                            <a asp-action="Delete" asp-route-id="@s.Id" class="btn-forge-link">Delete</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model != null && Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-forge">
            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="?page=@i&pageSize=@Model.PageSize&firstName=@Context.Request.Query["firstName"]&lastName=@Context.Request.Query["lastName"]&email=@Context.Request.Query["email"]">@i</a>
                </li>
            }
        </ul>
    </nav>
}
<div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
    <p class="text-total mb-0">Total: @(Model?.TotalCount ?? 0)</p>
    <button type="button" id="btnRefreshAjax" class="btn btn-forge btn-forge-outline btn-sm">Refresh</button>
</div>

@section Scripts {
<script>
(function() {
    var btn = document.getElementById('btnRefreshAjax');
    if (!btn) return;
    btn.addEventListener('click', function() {
        var qs = new URLSearchParams(window.location.search);
        var url = '/Students/ListJson?page=' + (qs.get('page') || '1') + '&pageSize=' + (qs.get('pageSize') || '10');
        if (qs.get('firstName')) url += '&firstName=' + encodeURIComponent(qs.get('firstName'));
        if (qs.get('lastName')) url += '&lastName=' + encodeURIComponent(qs.get('lastName'));
        if (qs.get('email')) url += '&email=' + encodeURIComponent(qs.get('email'));
        btn.disabled = true;
        var downloadUrl = '@Url.Action("Download", "Files")';
        fetch(url, { headers: { 'Accept': 'application/json' } })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var tbody = document.querySelector('.table-forge tbody');
                if (!tbody || !data.items) return;
                var isAdmin = @Html.Raw(isAdmin ? "true" : "false");
                var rows = data.items.map(function(s) {
                    var cells = '';
                    if (isAdmin && s.id != null) cells += '<td>' + s.id + '</td>';
                    var imgCell = s.profileImageUrl ? '<td><img src="' + downloadUrl + '?path=' + encodeURIComponent(s.profileImageUrl) + '" alt="" class="rounded" style="max-height: 40px; max-width: 40px; object-fit: cover;" /></td>' : '<td><span class="text-muted">—</span></td>';
                    cells += imgCell + '<td>' + (s.firstName || '') + '</td><td>' + (s.lastName || '') + '</td><td>' + (s.email || '') + '</td><td>' + (s.birthDate ? s.birthDate.split('T')[0] : '') + '</td>';
                    if (isAdmin && s.id) cells += '<td><a href="/Students/Details/' + s.id + '" class="btn-forge-link">Details</a> <span class="text-muted">|</span> <a href="/Students/Edit/' + s.id + '" class="btn-forge-link">Edit</a> <span class="text-muted">|</span> <a href="/Students/Delete/' + s.id + '" class="btn-forge-link">Delete</a></td>';
                    return '<tr>' + cells + '</tr>';
                });
                tbody.innerHTML = rows.join('');
            })
            .finally(function() { btn.disabled = false; });
    });
})();
</script>
}
