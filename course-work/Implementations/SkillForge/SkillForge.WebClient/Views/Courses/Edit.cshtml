@model CourseDto
@{
    ViewData["Title"] = "Edit Course";
}

<h2 class="page-title">Edit Course</h2>
<div class="card-forge p-4" style="max-width: 560px;">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="form-forge">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" type="number" step="0.01" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="DurationHours" class="form-label"></label>
            <input asp-for="DurationHours" type="number" class="form-control" />
            <span asp-validation-for="DurationHours" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label d-flex align-items-center gap-2">
                <input asp-for="IsActive" type="checkbox" class="form-check-input" />
                Active
            </label>
        </div>
        <div class="mb-3">
            <label class="form-label">Course Material (optional)</label>
            @if (!string.IsNullOrEmpty(Model.MaterialFileUrl))
            {
                <p class="mb-2 text-muted small">Current file is attached. Upload a new file to replace it.</p>
            }
            <input type="file" name="materialFile" accept=".pdf,.doc,.docx" class="form-control" />
            <small class="text-muted">PDF or Word (.pdf, .doc, .docx). Max 5MB. Leave empty to keep current.</small>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-forge btn-forge-primary">Save</button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-forge btn-forge-secondary">Cancel</a>
        </div>
    </form>
</div>
