@model CourseDto
@{
    ViewData["Title"] = "Course Details";
    var isAdmin = Context.IsAdmin();
}

<h2 class="page-title">Course Details</h2>
@if (TempData["Warning"] is string warning)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">@warning<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
}
@if (TempData["EnrollSuccess"] is string enrollSuccess)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">@enrollSuccess<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
}
@if (TempData["EnrollError"] is string enrollError)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">@enrollError<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
}
<div class="card-forge p-4">
    <dl class="row dl-forge mb-0">
        @if (isAdmin)
        {
            <dt class="col-sm-3">Id</dt><dd class="col-sm-9">@Model.Id</dd>
        }
        <dt class="col-sm-3">Title</dt><dd class="col-sm-9">@Model.Title</dd>
        <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
        <dt class="col-sm-3">Price</dt><dd class="col-sm-9">@Model.Price.ToString("C")</dd>
        <dt class="col-sm-3">Duration (hours)</dt><dd class="col-sm-9">@Model.DurationHours</dd>
        <dt class="col-sm-3">Active</dt><dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
        <dt class="col-sm-3">Created</dt><dd class="col-sm-9">@Model.CreatedAt.ToString("g")</dd>
        @if (!string.IsNullOrEmpty(Model.MaterialFileUrl))
        {
            <dt class="col-sm-3">Material</dt>
            <dd class="col-sm-9">
                <a href="@Url.Action("Download", "Files", new { path = Model.MaterialFileUrl })" target="_blank" rel="noopener" download class="btn btn-forge btn-forge-outline btn-sm">Download course material</a>
            </dd>
        }
    </dl>
</div>
<div class="mt-3 d-flex gap-2 flex-wrap">
    <a asp-action="Index" class="btn btn-forge btn-forge-outline">Back to List</a>
    @if (isAdmin)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-forge btn-forge-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-forge btn-forge-secondary">Delete</a>
    }
    else if (Model.IsActive)
    {
        <form asp-action="Enroll" asp-route-id="@Model.Id" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-forge btn-forge-primary">Enroll in this course</button>
        </form>
    }
</div>
