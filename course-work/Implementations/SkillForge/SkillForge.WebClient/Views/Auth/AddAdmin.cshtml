@model RegisterDto
@{
    ViewData["Title"] = "Add Admin";
}

<h2 class="page-title">Add Admin</h2>
@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">@success<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>
}
<div class="card-forge p-4 auth-card-forge" style="max-width: 520px;">
    <p class="text-muted mb-3">Create a new user account with admin rights. They will be able to manage students, courses, and enrollments.</p>
    <form asp-action="AddAdmin" method="post" class="form-forge">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="FirstName" class="form-label"></label>
                <input asp-for="FirstName" class="form-control" placeholder="First name" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LastName" class="form-label"></label>
                <input asp-for="LastName" class="form-control" placeholder="Last name" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
        </div>
        <div class="mb-3 mt-3">
            <label asp-for="UserName" class="form-label"></label>
            <input asp-for="UserName" class="form-control" placeholder="Username" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" type="email" class="form-control" placeholder="admin@example.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="BirthDate" class="form-label"></label>
            <input asp-for="BirthDate" type="date" class="form-control" />
            <span asp-validation-for="BirthDate" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" type="password" class="form-control" placeholder="At least 6 characters" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <div class="d-flex gap-2 flex-wrap">
            <button type="submit" class="btn btn-forge btn-forge-primary">Create Admin</button>
            <a asp-action="Index" asp-controller="Home" class="btn btn-forge btn-forge-secondary">Back to Home</a>
        </div>
    </form>
</div>
