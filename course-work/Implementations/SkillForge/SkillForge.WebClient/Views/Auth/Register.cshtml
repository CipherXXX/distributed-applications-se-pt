@model RegisterDto
@{
    ViewData["Title"] = "Register";
}

<div class="card-forge mx-auto auth-card-forge" style="max-width: 520px;">
    <div class="card-header">Register</div>
    <div class="card-body p-4">
        <p class="text-muted mb-3">Create your account. You'll be able to enroll in courses and manage your enrollments.</p>
        <form asp-action="Register" method="post" class="form-forge">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" placeholder="First name" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" placeholder="Last name" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3 mt-3">
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-control" placeholder="Choose username" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" type="email" class="form-control" placeholder="your@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="BirthDate" class="form-label"></label>
                <input asp-for="BirthDate" type="date" class="form-control" />
                <span asp-validation-for="BirthDate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control" placeholder="At least 6 characters" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" class="btn btn-forge btn-forge-primary">Register</button>
                <a asp-action="Login" class="btn btn-forge btn-forge-secondary">Login</a>
            </div>
        </form>
    </div>
</div>
